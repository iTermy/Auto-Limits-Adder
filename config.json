{
  "poll_interval_seconds": 5,
  "filters": {
    "instruments": {
      "mode": "exclude",
      "list": [
        "USOILSPOT"
      ]
    },
    "asset_classes": {
      "mode": "all",
      "list": [
        "metals",
        "forex"
      ]
    },
    "directions": "both",
    "scalp_signals": true,
    "signal_types": "all"
  },
  "proximity_filter": {
    "enabled": false,
    "default_pips": 500,
    "per_asset_class": {
      "metals": 500,
      "forex": 200,
      "indices": 1000,
      "crypto": 2000,
      "stocks": 300
    },
    "per_instrument": {
      "XAUUSD": 500
    }
  },
  "execution": {
    "risk_percent": 5.0,
    "min_lot": 0.01,
    "skip_if_price_past_limit": true,
    "place_all_limits_simultaneously": true,
    "lot_recheck_interval_seconds": 300
  },
  "tp": {
    "profit_threshold": {
      "unit": "pips",
      "default": 7,
      "per_instrument": {
        "XAUUSD": 2.0
      },
      "per_instrument_unit": {
        "XAUUSD": "dollars"
      }
    },
    "trail": {
      "unit": "pips",
      "default": 3,
      "per_instrument": {
        "XAUUSD": 2.0
      },
      "per_instrument_unit": {
        "XAUUSD": "dollars"
      }
    },
    "partial_close_percent": 50
  },
  "symbol_map": {
    "XAUUSD": "XAUUSD",
    "GOLD": "XAUUSD",
    "XAGUSD": "XAGUSD",
    "SILVER": "XAGUSD",
    "EURUSD": "EURUSD",
    "GBPUSD": "GBPUSD",
    "USDJPY": "USDJPY",
    "GBPJPY": "GBPJPY",
    "SPX500USD": "US500",
    "NAS100USD": "USTEC",
    "BTCUSDT": "BTCUSD",
    "ETHUSDT": "ETHUSD"
  },
  "live_prices": {
    "max_staleness_seconds": 30,
    "offset_readjust_interval_seconds": 60,
    "offset_readjust_threshold_pips": 2.0
  }
}